# SignPost - Generated Maddy Configuration
# DO NOT EDIT MANUALLY - This file is generated by SignPost web app
# Changes made here will be overwritten on next config regeneration
#
# Generated: {{.GeneratedAt}}

## Global settings
hostname {{.Hostname}}

state_dir /data/signpost/maddy_state
runtime_dir /tmp/maddy

## TLS configuration
{{- if or (eq .TLS.Mode "self-signed") (eq .TLS.Mode "")}}
{{- if and .TLS.CertPath .TLS.KeyPath}}
tls file {{.TLS.CertPath}} {{.TLS.KeyPath}}
{{- else}}
tls off
{{- end}}
{{- else if eq .TLS.Mode "manual"}}
tls file {{.TLS.CertPath}} {{.TLS.KeyPath}}
{{- else if eq .TLS.Mode "acme"}}
tls.loader.acme acme_tls {
    email {{.TLS.ACMEEmail}}
    agreed
    challenge dns-01
    {{- if eq .TLS.ACMEProvider "cloudflare"}}
    dns cloudflare {
        api_token {env:SIGNPOST_CF_API_TOKEN}
    }
    {{- end}}
}
tls &acme_tls
{{- end}}

## ---------------------------------------------------------------
## Relay targets (one per domain with smarthost relay)
## ---------------------------------------------------------------
{{- range $i, $d := .Domains}}
{{- if and $d.Active $d.Relay}}
{{- if $d.Relay.MsmtpProxy}}

target.smtp relay_{{$i}} {
    targets tcp://127.0.0.1:2500
    attempt_starttls no
}
{{- else}}

target.smtp relay_{{$i}} {
    targets tcp://{{$d.Relay.Host}}:{{$d.Relay.Port}}
    {{- if $d.Relay.StartTLS}}
    starttls yes
    {{- end}}
    {{- if and $d.Relay.Username $d.Relay.Password}}
    auth plain "{{$d.Relay.Username}}" "{{$d.Relay.Password}}"
    {{- end}}
}
{{- end}}
{{- end}}
{{- end}}

## ---------------------------------------------------------------
## Remote delivery (direct delivery and same-domain bypass)
## ---------------------------------------------------------------
{{- if or .NeedsDirectDelivery .HasRelayDomains}}

target.remote outbound_delivery {
    mx_auth {
        mtasts {
            cache fs
            fs_dir /data/signpost/maddy_state/mtasts_cache
        }
        local_policy {
            min_tls_level encrypted
            min_mx_level none
        }
    }
}

target.queue remote_queue {
    target &outbound_delivery
    autogenerated_msg_domain {{.PrimaryDomain}}
    bounce {
        default_destination {
            reject 550 5.0.0 "Refusing to send DSN to non-local address"
        }
    }
}
{{- end}}

## ---------------------------------------------------------------
## Authentication for submission port
## ---------------------------------------------------------------
{{- if .SMTPUsers}}

auth.pass_table local_auth {
    table sql_table {
        driver sqlite3
        dsn /data/signpost/signpost.db
        table_name smtp_users
        key_column username
        value_column password_hash
    }
}
{{- end}}

## ---------------------------------------------------------------
## SMTP endpoint - local services (port {{.SMTPPort}}, no auth)
## Network trust is enforced by Docker networking / firewall,
## not by Maddy config. Only expose port 25 to trusted networks.
## ---------------------------------------------------------------
{{- if .SMTPEnabled}}

smtp tcp://0.0.0.0:{{.SMTPPort}} {
    limits {
        all rate 20 1s
        all concurrency 10
    }

    {{- range $i, $d := .Domains}}
    {{- if $d.Active}}

    source {{$d.Name}} {
        {{- if $d.DKIMKeyPath}}
        modify {
            dkim {
                domains {{$d.Name}}
                selector {{$d.DKIMSelector}}
                key_path {{$d.DKIMKeyPath}}
            }
        }
        {{- end}}
        {{- if $d.Relay}}
        destination {{$d.Name}} {
            deliver_to &remote_queue
        }
        {{- end}}
        default_destination {
            {{- if $d.Relay}}
            deliver_to &relay_{{$i}}
            {{- else}}
            deliver_to &remote_queue
            {{- end}}
        }
    }
    {{- end}}
    {{- end}}

    default_source {
        default_destination {
            reject 550 5.7.1 "Sender domain not configured in SignPost"
        }
    }
}
{{- end}}

## ---------------------------------------------------------------
## Submission endpoint - authenticated (port {{.SubmissionPort}})
## Only enabled when submission is enabled and SMTP users exist.
## ---------------------------------------------------------------
{{- if .SubmissionEnabled}}

submission tcp://0.0.0.0:{{.SubmissionPort}} {
    limits {
        all rate 50 1s
        all concurrency 20
    }

    auth &local_auth

    {{- range $i, $d := .Domains}}
    {{- if $d.Active}}

    source {{$d.Name}} {
        {{- if $d.DKIMKeyPath}}
        modify {
            dkim {
                domains {{$d.Name}}
                selector {{$d.DKIMSelector}}
                key_path {{$d.DKIMKeyPath}}
            }
        }
        {{- end}}
        {{- if $d.Relay}}
        destination {{$d.Name}} {
            deliver_to &remote_queue
        }
        {{- end}}
        default_destination {
            {{- if $d.Relay}}
            deliver_to &relay_{{$i}}
            {{- else}}
            deliver_to &remote_queue
            {{- end}}
        }
    }
    {{- end}}
    {{- end}}

    default_source {
        default_destination {
            reject 550 5.7.1 "Sender domain not configured in SignPost"
        }
    }
}
{{- end}}
