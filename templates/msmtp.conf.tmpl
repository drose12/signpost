# SignPost - Generated msmtp Configuration
# DO NOT EDIT MANUALLY - Regenerated by SignPost on relay config changes
# Generated: {{.GeneratedAt}}

defaults
tls            on
tls_starttls   on
tls_certcheck  off
logfile        /tmp/msmtp.log

{{- range $i, $d := .Domains}}
{{- if and $d.Active $d.Relay (eq $d.Relay.AuthMethod "login")}}

account relay_{{$i}}
host {{$d.Relay.Host}}
port {{$d.Relay.Port}}
auth login
user {{$d.Relay.Username}}
password {{$d.Relay.Password}}
{{- if not $d.Relay.StartTLS}}
tls_starttls   off
{{- end}}
{{- end}}
{{- end}}

account default : relay_0
