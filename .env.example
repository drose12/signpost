# SignPost Environment Variables
# Copy this file to .env and fill in the values

# Required
SIGNPOST_DOMAIN=drcs.ca
SIGNPOST_SECRET_KEY=           # Min 32 chars, used to encrypt relay credentials

# Required on first run
SIGNPOST_ADMIN_PASS=           # Web UI admin password

# Optional
SIGNPOST_ENV=dev               # dev or prod
SIGNPOST_HOSTNAME=             # Defaults to mail.$SIGNPOST_DOMAIN
SIGNPOST_ADMIN_USER=admin      # Web UI admin username
SIGNPOST_WEB_PORT=8080
SIGNPOST_SMTP_PORT=25
SIGNPOST_SUBMISSION_PORT=587
SIGNPOST_LOG_LEVEL=info        # debug, info, warn, error

# Let's Encrypt (optional, for ACME DNS-01 via Cloudflare)
SIGNPOST_ACME_EMAIL=
SIGNPOST_CF_API_TOKEN=
